///|
fn create_company(conn : Connection) -> Unit raise SqliteError {
  let stmt = conn.prepare(
    (
      #|CREATE TABLE COMPANY(
      #|  ID INT PRIMARY KEY     NOT NULL,
      #|  NAME           BLOB    NOT NULL,
      #|  AGE            INT     NOT NULL,
      #|  ADDRESS        BLOB,
      #|  SALARY         REAL
      #|);
    ),
  )
  stmt.step_once()
  stmt.finalize()
}

///|
fn insert_company(conn : Connection) -> Unit raise SqliteError {
  let stmt = conn.prepare(
    (
      #|INSERT INTO COMPANY (ID,NAME,AGE,ADDRESS,SALARY) VALUES (?,?,?,?,?);
    ),
  )
  stmt.bind(index=1, 1)
  stmt.bind(index=2, "Paul")
  stmt.bind(index=3, 32)
  stmt.bind(index=4, "California")
  stmt.bind(index=5, 20000.00)
  stmt.step_once()
  stmt.finalize()
}

///|
fn select_company(conn : Connection) -> Unit raise {
  let stmt = conn.prepare(
    (
      #|SELECT * from COMPANY
    ),
  )
  if stmt.step() {
    let column0 : Int = stmt.column(index=0)
    assert_eq(column0, 1)
    let column1 : String = stmt.column(index=1)
    assert_eq(column1, "Paul")
    let column3 : String = stmt.column(index=3)
    assert_eq(column3, "California")
    let column4 : Double = stmt.column(index=4)
    assert_eq(column4.to_int(), 20000)
  }
  stmt.finalize()
}

///|
test {
  let conn = Connection::open(":memory:")
  create_company(conn)
  insert_company(conn)
  select_company(conn)
  conn.close()
}
